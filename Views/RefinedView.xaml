<ui:FluentWindow x:Class="SCCMAdPrep.Views.RefinedView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="SCCM AD Preparation Tool"
        Width="1200" Height="800"
        MinWidth="860" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>

        <!-- Sidebar section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8C8CA0"/>
            <Setter Property="Margin" Value="20,20,0,8"/>
        </Style>

        <!-- Content page heading -->
        <Style x:Key="PageHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Content page subheading -->
        <Style x:Key="PageSubheading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#8888A0"/>
            <Setter Property="Margin" Value="0,0,0,28"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Clean card -->
        <Style x:Key="CleanCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E8E8EE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Info box -->
        <Style x:Key="InfoBox" TargetType="Border">
            <Setter Property="Background" Value="#EDF5FB"/>
            <Setter Property="BorderBrush" Value="#CCE1F2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,16,0,0"/>
        </Style>

        <!-- Nav item template -->
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4,1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#131210"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="AccentBar" Width="3" HorizontalAlignment="Left"
                                    CornerRadius="0,2,2,0" Background="Transparent"
                                    Margin="-8,3,0,3"/>
                            <Border x:Name="Bd" Background="Transparent"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}"
                                    BorderBrush="Transparent" BorderThickness="1">
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F9F9F9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F9F9F9"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E0DDD8"/>
                                <Setter TargetName="AccentBar" Property="Background" Value="#006ABB"/>
                                <Setter Property="Foreground" Value="#006ABB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Background="#F5F5F5">
            <ui:TitleBar Title="SCCM AD Preparation Tool" Background="#F5F5F5"
                         Height="32" Padding="8,0"/>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP: Sidebar + Content -->
            <Grid Grid.Row="0" Background="#F5F5F5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ============================================================ -->
                <!-- LEFT SIDEBAR                                                  -->
                <!-- ============================================================ -->
                <Border Grid.Column="0" Background="#F5F5F5">
                    <DockPanel>

                        <!-- Brand / Domain -->
                        <Border DockPanel.Dock="Top" Padding="18,16,18,12">
                            <StackPanel>
                                <TextBlock Text="SCCM AD Prep" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#1A1A2E" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtDomain" Text="{Binding DomainDisplay}"
                                           FontSize="11" Foreground="#9090A4"/>
                            </StackPanel>
                        </Border>

                        <!-- About (am unteren Rand fixiert) -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,10">
                            <Separator Background="#E0DDD8" Margin="16,0,16,6"/>
                            <ListBox x:Name="NavList5" Background="Transparent" BorderThickness="0"
                                     Padding="8,6,8,0" SelectionChanged="NavList5_SelectionChanged"
                                     ItemContainerStyle="{StaticResource NavItemStyle}">
                                <ListBoxItem Tag="About">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Info24" FontSize="16" Margin="0,0,10,0"/>
                                        <TextBlock Text="About" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ListBoxItem>
                            </ListBox>
                        </StackPanel>

                        <!-- Navigation Sections -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <TextBlock Text="CONFIGURATION" Style="{StaticResource SectionHeader}"/>

                                <ListBox x:Name="NavList" Background="Transparent" BorderThickness="0"
                                         Padding="8,0" SelectionChanged="NavList_SelectionChanged"
                                         ItemContainerStyle="{StaticResource NavItemStyle}">
                                    <ListBoxItem Tag="Prerequisites">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Prerequisites" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>

                                <TextBlock Text="ACTIVE DIRECTORY" Style="{StaticResource SectionHeader}"/>

                                <ListBox x:Name="NavList2" Background="Transparent" BorderThickness="0"
                                         Padding="8,0" SelectionChanged="NavList2_SelectionChanged"
                                         ItemContainerStyle="{StaticResource NavItemStyle}">
                                    <ListBoxItem Tag="OUs">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Folder24" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="OU Structure" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Container">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Box24" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="System Management" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Groups">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="PeopleTeam24" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Security Groups" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>

                                <TextBlock Text="ACCOUNTS" Style="{StaticResource SectionHeader}"/>

                                <ListBox x:Name="NavList3" Background="Transparent" BorderThickness="0"
                                         Padding="8,0" SelectionChanged="NavList3_SelectionChanged"
                                         ItemContainerStyle="{StaticResource NavItemStyle}">
                                    <ListBoxItem Tag="Accounts">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Person24" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Service Accounts" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="GMSA">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Key24" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="gMSA" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Extras">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Settings24" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Extras" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>

                                <TextBlock Text="OUTPUT" Style="{StaticResource SectionHeader}"/>

                                <ListBox x:Name="NavList4" Background="Transparent" BorderThickness="0"
                                         Padding="8,0" SelectionChanged="NavList4_SelectionChanged"
                                         ItemContainerStyle="{StaticResource NavItemStyle}">
                                    <ListBoxItem Tag="Log">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Log" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>

                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ============================================================ -->
                <!-- CONTENT AREA                                                  -->
                <!-- ============================================================ -->
                <Border Grid.Column="1" Background="#F9F9F9"
                        CornerRadius="12,0,0,0" ClipToBounds="True"
                        BorderBrush="#E0DDD8" BorderThickness="1,0,0,0">
                    <Grid>

                        <!-- Regular content pages (scrollable) -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="36,28,36,16">
                            <Grid>

                                <!-- ============================================ -->
                                <!-- PAGE: Voraussetzungen                        -->
                                <!-- ============================================ -->
                                <StackPanel x:Name="PagePrerequisites" Visibility="Visible">
                                    <TextBlock Text="Prerequisites" Style="{StaticResource PageHeading}"/>
                                    <TextBlock Style="{StaticResource PageSubheading}">
                                        These checks are validated before execution.
                                    </TextBlock>

                                    <Border Style="{StaticResource CleanCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="AD PowerShell Module" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                <TextBlock Text="Checks if the ActiveDirectory module is available."
                                                           FontSize="11.5" Foreground="#9090A4" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CheckAdModule}"
                                                             OnContent="" OffContent="" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource CleanCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Domain Connectivity" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                <TextBlock Text="Checks if a Domain Controller is reachable."
                                                           FontSize="11.5" Foreground="#9090A4" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CheckDomain}"
                                                             OnContent="" OffContent="" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource CleanCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="SCCM Server Computer Object" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                <TextBlock Text="Checks if the computer object exists in Active Directory."
                                                           FontSize="11.5" Foreground="#9090A4" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CheckSccmServer}"
                                                             OnContent="" OffContent="" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource CleanCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Schema Admin Permissions" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                <TextBlock Text="Checks if the current user is a Schema Admin."
                                                           FontSize="11.5" Foreground="#9090A4" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CheckSchemaAdmin}"
                                                             OnContent="" OffContent="" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <ui:Button Content="Check Prerequisites" Appearance="Primary" FontSize="12.5"
                                               Padding="24,10" Margin="0,24,0,0" HorizontalAlignment="Right"
                                               Command="{Binding RunPrerequisitesOnlyCommand}"
                                               Icon="{ui:SymbolIcon ShieldCheckmark24}"/>
                                </StackPanel>

                                <!-- ============================================ -->
                                <!-- PAGE: OU-Struktur                            -->
                                <!-- ============================================ -->
                                <StackPanel x:Name="PageOUs" Visibility="Collapsed">
                                    <TextBlock Text="OU Structure" Style="{StaticResource PageHeading}"/>
                                    <TextBlock Style="{StaticResource PageSubheading}">
                                        <Run Text="Organizational units under"/>
                                        <Run Text="{Binding OuPathDisplay, Mode=OneWay}" FontWeight="SemiBold" Foreground="#006ABB"/>
                                    </TextBlock>

                                    <!-- Root OU (moved from Server page) -->
                                    <Border Style="{StaticResource CleanCard}">
                                        <StackPanel>
                                            <TextBlock Text="Root OU" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#1A1A2E" Margin="0,0,0,6"/>
                                            <TextBlock Text="Name of the parent organizational unit. All sub-OUs will be created underneath."
                                                       FontSize="11.5" Foreground="#9090A4" Margin="0,0,0,14" TextWrapping="Wrap"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ui:TextBox Grid.Column="0" Text="{Binding RootOu, UpdateSourceTrigger=PropertyChanged}"
                                                            FontSize="13" Padding="12,10"/>
                                                <ui:Button Grid.Column="1" Content="Browse" Command="{Binding BrowseOuCommand}"
                                                           Appearance="Primary" Margin="10,0,0,0" Padding="16,10"
                                                           FontSize="12" VerticalAlignment="Stretch" Cursor="Hand">
                                                    <ui:Button.Icon>
                                                        <ui:SymbolIcon Symbol="FolderOpen24"/>
                                                    </ui:Button.Icon>
                                                </ui:Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- OU Structure -->
                                    <Border Style="{StaticResource CleanCard}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Create OU Structure" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1A1A2E" VerticalAlignment="Center"/>
                                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CreateOus}"
                                                                 OnContent="" OffContent="" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Border Background="#FAFAFE" CornerRadius="6" Padding="16,12"
                                                    BorderBrush="#F0F0F6" BorderThickness="1">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="1" Text="SUB-OU" FontSize="10" FontWeight="SemiBold" Foreground="#9090A4"/>
                                                        <TextBlock Grid.Column="2" Text="DESCRIPTION" FontSize="10" FontWeight="SemiBold" Foreground="#9090A4"/>
                                                    </Grid>
                                                    <Separator Background="#EDEDF4" Margin="0,0,0,8"/>

                                                    <ItemsControl ItemsSource="{Binding SubOus}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,3,0,3">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <ui:ToggleSwitch IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                                     OnContent="" OffContent=""
                                                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12.5"
                                                                               Foreground="#2A2A40" VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding Description}" FontSize="11.5"
                                                                               Foreground="#9090A4" VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Disable deletion protection (Lab) -->
                                    <Border Background="#FFFBF0" BorderBrush="#F0E4C8" BorderThickness="1"
                                            CornerRadius="8" Padding="18,16" Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Disable Deletion Protection" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                <TextBlock Text="Disables 'Protect object from accidental deletion' for all created OUs. Ideal for lab environments."
                                                           FontSize="11.5" Foreground="#9090A4" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding DisableProtectFromDeletion}"
                                                             OnContent="" OffContent="" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <ui:Button Content="Create OUs" Appearance="Primary" FontSize="12.5"
                                               Padding="24,10" Margin="0,14,0,0" HorizontalAlignment="Right"
                                               Command="{Binding RunOusOnlyCommand}"
                                               Icon="{ui:SymbolIcon Folder24}"/>
                                </StackPanel>

                                <!-- ============================================ -->
                                <!-- PAGE: System Management Container            -->
                                <!-- ============================================ -->
                                <StackPanel x:Name="PageContainer" Visibility="Collapsed">
                                    <TextBlock Text="System Management" Style="{StaticResource PageHeading}"/>
                                    <TextBlock Style="{StaticResource PageSubheading}">
                                        The System Management container is required for SCCM to publish site data to Active Directory.
                                    </TextBlock>

                                    <!-- SCCM Server Name (placed here because ACL is set for this server) -->
                                    <Border Style="{StaticResource CleanCard}">
                                        <StackPanel>
                                            <TextBlock Text="SCCM Server Name" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#1A1A2E" Margin="0,0,0,6"/>
                                            <TextBlock Text="The hostname of the primary SCCM/MECM site server. Required for ACL permissions."
                                                       FontSize="11.5" Foreground="#9090A4" Margin="0,0,0,14" TextWrapping="Wrap"/>
                                            <ui:TextBox PlaceholderText="e.g. SCCM01" FontSize="13"
                                                        Text="{Binding SccmServer, UpdateSourceTrigger=PropertyChanged}"
                                                        Padding="12,10"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CleanCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Create System Management Container" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                <TextBlock Text="Creates CN=System Management under CN=System in Active Directory."
                                                           FontSize="11.5" Foreground="#9090A4" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CreateSysMgmt}"
                                                             OnContent="" OffContent="" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource CleanCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Set Full Control ACL" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                <TextBlock Text="Grants Full Control to the SCCM server with inheritance."
                                                           FontSize="11.5" Foreground="#9090A4" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding SetSysMgmtAcl}"
                                                             OnContent="" OffContent="" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource InfoBox}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Info16" Foreground="#006ABB" Margin="0,1,12,0"
                                                           VerticalAlignment="Top" FontSize="14"/>
                                            <TextBlock FontSize="11.5" TextWrapping="Wrap" Foreground="#6C6C88" MaxWidth="500">
                                                Without Full Control on the System Management container, SCCM
                                                cannot publish site information to Active Directory.
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Schema Extension -->
                                    <Border Style="{StaticResource CleanCard}" Margin="0,16,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Extend AD Schema (extadsch.exe)" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                <TextBlock Text="Runs extadsch.exe to extend the AD schema for SCCM. Place extadsch.exe next to SCCMAdPrep.exe (from SMSSETUP\BIN\X64\)."
                                                           FontSize="11.5" Foreground="#9090A4" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ExtendSchema}"
                                                             OnContent="" OffContent="" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <Border Background="#FFFBF0" BorderBrush="#F0E4C8" BorderThickness="1"
                                            CornerRadius="8" Padding="16,14" Margin="0,10,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Warning24" Foreground="#9A7B20" Margin="0,1,12,0"
                                                           VerticalAlignment="Top" FontSize="14"/>
                                            <TextBlock FontSize="11.5" TextWrapping="Wrap" Foreground="#8B7020" MaxWidth="500">
                                                <Run FontWeight="SemiBold">Requires Schema Admin rights.</Run>
                                                <Run Text="The result will be logged from C:\extadsch.log after execution."/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <ui:Button Content="Execute" Appearance="Primary" FontSize="12.5"
                                               Padding="24,10" Margin="0,24,0,0" HorizontalAlignment="Right"
                                               Command="{Binding RunContainerOnlyCommand}"
                                               Icon="{ui:SymbolIcon Box24}"/>
                                </StackPanel>

                                <!-- ============================================ -->
                                <!-- PAGE: Security Groups                        -->
                                <!-- ============================================ -->
                                <StackPanel x:Name="PageGroups" Visibility="Collapsed">
                                    <TextBlock Text="Security Groups" Style="{StaticResource PageHeading}"/>
                                    <TextBlock Style="{StaticResource PageSubheading}">
                                        <Run Text="Will be created in"/>
                                        <Run Text="{Binding GroupsPathDisplay, Mode=OneWay}" FontWeight="SemiBold" Foreground="#006ABB"/>
                                    </TextBlock>

                                    <!-- Alle Gruppen in einer Card: User + Device -->
                                    <Border Style="{StaticResource CleanCard}">
                                        <StackPanel>

                                            <!-- USER GROUPS -->
                                            <TextBlock Text="USER GROUPS" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="#9090A4" Margin="0,0,0,10"/>

                                            <ItemsControl ItemsSource="{Binding UserGroups}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3,0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                                <TextBlock Text="{Binding Description}" FontSize="11.5" Foreground="#9090A4" Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                            <ComboBox Grid.Column="1" SelectedItem="{Binding Scope, Mode=TwoWay}"
                                                                      FontSize="11" Margin="12,0" VerticalAlignment="Center"
                                                                      MinWidth="110" Padding="8,4">
                                                                <sys:String>Global</sys:String>
