                                    <!-- Log Header -->
                                    <Border Grid.Row="0" Background="#F5F5F5" Padding="18,8"
                                            BorderBrush="#E0DDD8" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="7" Height="7" Fill="#16A34A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Output" FontSize="11.5" FontWeight="SemiBold" Foreground="#8888A0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <ui:Button Content="Clear" Appearance="Secondary" FontSize="10.5"
                                                           Padding="12,4" Margin="0,0,6,0"
                                                           Command="{Binding ClearLogCommand}"
                                                           Icon="{ui:SymbolIcon Delete24}"/>
                                                <ui:Button Content="Export" Appearance="Secondary" FontSize="10.5"
                                                           Padding="12,4"
                                                           Command="{Binding ExportLogCommand}"
                                                           Icon="{ui:SymbolIcon ArrowDownload24}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Log Content (full height) -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,10"
                                                  x:Name="LogScrollViewer">
                                        <TextBlock FontFamily="Cascadia Code,Consolas,Courier New" FontSize="11.5"
                                                   Foreground="#505068" LineHeight="22" TextWrapping="Wrap"
                                                   Text="{Binding LogText}"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                    </Grid>
                </Border>

            </Grid>

            <!-- ============================================================ -->
            <!-- BOTTOM ACTION BAR                                             -->
            <!-- ============================================================ -->
            <Border Grid.Row="1" Background="#F5F5F5" Padding="18,8"
                    BorderBrush="#E0DDD8" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#16A34A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStatus" Text="{Binding StatusText}" FontSize="11.5" Foreground="#606078"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
